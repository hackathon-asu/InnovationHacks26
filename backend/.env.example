# ── AntonRX Backend ─────────────────────────────────────────
# Copy this file to .env and fill in your values
# cp .env.example .env

# ── General ─────────────────────────────────────────────────
ENVIRONMENT=development
UPLOAD_DIR=uploads
LLM_PROVIDER=gemini          # gemini | ollama | groq | nvidia | anthropic

# ── Database (Neon Postgres with pgvector) ──────────────────
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname?ssl=require

# ── Gemini / Google AI ──────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemma-4-31b-it

# ── Ollama (local dev) ──────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── NVIDIA Build (embeddings + LLM) ────────────────────────
NVIDIA_API_KEY=
NVIDIA_MODEL=deepseek-ai/deepseek-v3.2
NVIDIA_EMBED_MODEL=nvidia/nv-embedqa-e5-v5

# ── Groq (fast cloud fallback) ─────────────────────────────
GROQ_API_KEY=

# ── Anthropic (optional) ───────────────────────────────────
ANTHROPIC_API_KEY=

# ── Google Custom Search (policy auto-fetch) ────────────────
GOOGLE_CSE_KEY=
GOOGLE_CSE_ID=

# ── CORS (comma-separated, for production) ──────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
