# ── LLM Provider (pick one: gemini | ollama | groq | nvidia) ──
LLM_PROVIDER=ollama

# ── Gemini (ai.google.dev free key) ──
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Ollama (local, run: ollama pull qwen3:4b && ollama pull nomic-embed-text) ──
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Groq (console.groq.com free key) ──
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ── NVIDIA Build (build.nvidia.com free key, nvapi-xxx) ──
NVIDIA_API_KEY=
NVIDIA_MODEL=writer/palmyra-med-70b-32k
NVIDIA_EMBED_MODEL=nvidia/nv-embedqa-e5-v5

# ── Database ──
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/antonrx

# ── Other ──
UPLOAD_DIR=uploads
ENVIRONMENT=development
